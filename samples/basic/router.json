{
  "apiVersion": "kimchi/v1",
  "kind": "Router",
  "metadata": {
    "name": "basic-router"
  },
  "spec": {
    "rules": [
      {
        "path": "/get",
        "pathType": "Exact",
        "methods": ["GET"]
      },
      {
        "path": "/post",
        "pathType": "Exact",
        "methods": ["POST"]
      },
      {
        "path": "/put",
        "pathType": "Exact",
        "methods": ["PUT"]
      },
      {
        "path": "/delete",
        "pathType": "Exact",
        "methods": ["DELETE"]
      },
      {
        "path": "/anything",
        "pathType": "Exact"
      }
    ],
    "config": {
      "destinations": [
        {
          "destinationRef": { "kind": "Service", "name": "httpbin" },
          "weight": 100
        }
      ]
    }
  }
}
